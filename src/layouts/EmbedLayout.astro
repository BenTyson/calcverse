---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;

// Derive the calculator slug (e.g. "freelance/quarterly-tax-calculator")
// from the embed URL so we can tag the backlink with a UTM campaign.
// Attribution lands via Umami on calcfalcon.com — no third-party tracking
// script loaded on the host site.
const embedPath = Astro.url.pathname.replace(/^\/embed\/?/, '').replace(/\/$/, '');
const utmCampaign = embedPath || 'unknown';
const backlinkUrl = `https://calcfalcon.com/?utm_source=embed&utm_medium=backlink&utm_campaign=${encodeURIComponent(utmCampaign)}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
  </head>
  <body class="bg-white p-4">
    <slot />
    <p class="text-center text-xs text-gray-400 mt-4">
      Powered by <a href={backlinkUrl} target="_blank" rel="noopener" class="text-primary-600 hover:underline">CalcFalcon</a>
    </p>
  </body>
</html>
