---
import '../styles/global.css';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { MONETIZATION } from '@lib/config/monetization';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  ogType?: string;
}

const {
  title,
  description,
  ogImage = '/og-images/default.svg',
  canonicalUrl,
  noIndex = false,
  ogType = 'website',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://calcfalcon.com';
const currentUrl = canonicalUrl || `${siteUrl}${Astro.url.pathname}`;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/Logo_Transparent2.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Inter Font (self-hosted) -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    {MONETIZATION.adsense.publisherId && (
      <meta name="google-adsense-account" content={MONETIZATION.adsense.publisherId} />
    )}
    <slot name="head" />
    <script is:inline src="https://cdn.usefathom.com/script.js" data-site="BRHGFMPN" defer></script>
  </head>
  <body class="min-h-screen bg-neutral-50 flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:top-4 focus:left-4 focus:px-4 focus:py-2 focus:bg-neutral-900 focus:text-white focus:rounded-lg focus:font-medium">
      Skip to content
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
