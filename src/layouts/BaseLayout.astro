---
import '../styles/global.css';
import Header from '@components/layout/Header.astro';
import Footer from '@components/layout/Footer.astro';
import { MONETIZATION } from '@lib/config/monetization';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalUrl?: string;
  noIndex?: boolean;
  ogType?: string;
}

const {
  title,
  description,
  ogImage = '/og-images/default.png',
  canonicalUrl,
  noIndex = false,
  ogType = 'website',
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://calcfalcon.com';
const currentUrl = canonicalUrl || `${siteUrl}${Astro.url.pathname}`;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/CalcFalc_Logo_Cyan.png" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#06b6d4" />

    <!-- Plus Jakarta Sans (self-hosted) -->
    <link rel="preload" href="/fonts/plus-jakarta-sans-latin.woff2" as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={currentUrl} />
    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={currentUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    {MONETIZATION.adsense.publisherId && (
      <meta name="google-adsense-account" content={MONETIZATION.adsense.publisherId} />
    )}
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-3941293108914142" crossorigin="anonymous" is:inline></script>
    <slot name="head" />
    {import.meta.env.PROD && (
      <script is:inline defer src="https://umami-production-3685.up.railway.app/script.js" data-website-id="789f1a13-f7d2-4a67-8888-2b5934ba4a94"></script>
    )}
  </head>
  <body class="min-h-screen bg-neutral-50 flex flex-col">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-[100] focus:top-4 focus:left-4 focus:px-4 focus:py-2 focus:bg-neutral-900 focus:text-white focus:rounded-lg focus:font-medium">
      Skip to content
    </a>
    <Header />
    <main id="main-content" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </body>
</html>
