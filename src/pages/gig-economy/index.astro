---
import BaseLayout from '@layouts/BaseLayout.astro';
import SchemaOrg from '@components/seo/SchemaOrg.astro';
import type { FAQ } from '@lib/seo/schema';

const faqs: FAQ[] = [
  {
    question: 'What is the best gig economy app to work for?',
    answer: 'DoorDash and Uber tend to have the highest volume of available work. Instacart often has the best per-hour earnings for selective shoppers. Many gig workers use multiple apps simultaneously to maximize earnings and reduce downtime.',
  },
  {
    question: 'Do gig workers pay taxes?',
    answer: 'Yes. Gig income is self-employment income, subject to income tax plus 15.3% self-employment tax. You\'ll receive 1099 forms and should make quarterly estimated tax payments if you expect to owe $1,000 or more.',
  },
  {
    question: 'How much do gig workers really make per hour?',
    answer: 'After expenses, most gig workers earn $12-20 per hour. Gross pay of $20-30/hour is significantly reduced by gas ($0.12-0.18 per mile), vehicle maintenance and depreciation, and taxes. Track all expenses carefully to know your real number.',
  },
];

const calculators = [
  {
    name: 'Uber/Lyft Driver Earnings Calculator',
    description: 'Calculate your true rideshare earnings after gas, maintenance, and depreciation',
    href: '/gig-economy/uber-lyft-calculator',
  },
  {
    name: 'DoorDash/Delivery Earnings Calculator',
    description: 'Track your delivery earnings and calculate your effective hourly rate',
    href: '/gig-economy/doordash-calculator',
  },
  {
    name: 'Instacart Shopper Calculator',
    description: 'Estimate your Instacart shopping earnings after gas and expenses',
    href: '/gig-economy/instacart-calculator',
  },
  {
    name: 'Airbnb Profit Calculator',
    description: 'Estimate your short-term rental profit after all fees and expenses',
    href: '/gig-economy/airbnb-calculator',
  },
];

const upcomingCalculators = [
  'TaskRabbit Earnings Calculator',
  'Amazon Flex Calculator',
  'Turo Car Rental Calculator',
];
---

<BaseLayout
  title="Gig Economy Calculators - Rideshare, Delivery & Rental | CalcFalcon"
  description="Free calculators for gig workers. Calculate your true earnings for Uber, Lyft, DoorDash, and Airbnb after all expenses."
>
  <Fragment slot="head">
    <SchemaOrg faqs={faqs} />
  </Fragment>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-gig-500 to-gig-600 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="w-16 h-16 rounded-2xl bg-white/20 backdrop-blur flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
      </div>
      <h1 class="heading-lg mb-4">Gig Economy Calculators</h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto">
        Tools for rideshare drivers, delivery workers, and short-term rental hosts
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-12 bg-white border-b border-neutral-100">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-neutral-700 leading-relaxed mb-4">
        Gig economy earnings look different on paper than in your pocket. Gas, vehicle depreciation, maintenance, and self-employment taxes significantly reduce your gross pay. Without accounting for these costs, it's easy to overestimate what you're actually earning per hour.
      </p>
      <p class="text-neutral-700 leading-relaxed">
        These calculators show your true hourly earnings after all costs, helping you make smarter decisions about which platforms to work on, when to drive, and whether gig work is worth it for your situation.
      </p>
    </div>
  </section>

  <!-- Calculators List -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid gap-6">
        {calculators.map((calc) => (
          <a
            href={calc.href}
            class="group block p-6 bg-white rounded-2xl border border-neutral-100 hover:border-gig-200 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
          >
            <h2 class="font-bold text-xl text-neutral-900 group-hover:text-gig-600 transition-colors">
              {calc.name}
            </h2>
            <p class="text-neutral-600 mt-2 leading-relaxed">{calc.description}</p>
            <span class="inline-flex items-center text-gig-600 font-semibold mt-4 group-hover:gap-2 transition-all">
              Use Calculator
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>

      <!-- Coming Soon -->
      <div class="mt-12 card-elevated p-6">
        <h3 class="font-bold text-neutral-900 mb-4 flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-gig-500 animate-pulse"></span>
          More Gig Economy Calculators Coming Soon
        </h3>
        <ul class="text-neutral-600 space-y-2">
          {upcomingCalculators.map((calc) => (
            <li class="flex items-center gap-3">
              <svg class="w-4 h-4 text-neutral-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
              </svg>
              {calc}
            </li>
          ))}
        </ul>
      </div>

      <!-- FAQs -->
      <div class="mt-12">
        <h2 class="heading-md text-neutral-900 mb-6">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="card-elevated p-5 group">
              <summary class="font-medium text-neutral-900 cursor-pointer list-none flex justify-between items-center gap-4">
                <span>{faq.question}</span>
                <svg class="w-5 h-5 text-neutral-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-neutral-600 leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
