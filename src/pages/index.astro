---
import BaseLayout from '@layouts/BaseLayout.astro';

const categories = [
  {
    name: 'Freelance',
    description: 'Calculate rates, taxes, and compare employment options',
    count: 4,
    href: '/freelance',
    gradient: 'from-freelance-500 to-freelance-600',
    bgLight: 'bg-freelance-50',
    borderColor: 'border-freelance-100 hover:border-freelance-300',
    textColor: 'text-freelance-600',
  },
  {
    name: 'Creator',
    description: 'Estimate revenue from YouTube, Twitch, and more',
    count: 7,
    href: '/creator',
    gradient: 'from-creator-500 to-creator-600',
    bgLight: 'bg-creator-50',
    borderColor: 'border-creator-100 hover:border-creator-300',
    textColor: 'text-creator-600',
  },
  {
    name: 'Gig Economy',
    description: 'Track earnings for rideshare, delivery, and rentals',
    count: 4,
    href: '/gig-economy',
    gradient: 'from-gig-500 to-gig-600',
    bgLight: 'bg-gig-50',
    borderColor: 'border-gig-100 hover:border-gig-300',
    textColor: 'text-gig-600',
  },
  {
    name: 'Side Hustle',
    description: 'Plan your path to financial goals',
    count: 1,
    href: '/side-hustle',
    gradient: 'from-sidehustle-500 to-sidehustle-600',
    bgLight: 'bg-sidehustle-50',
    borderColor: 'border-sidehustle-100 hover:border-sidehustle-300',
    textColor: 'text-sidehustle-600',
  },
  {
    name: 'Personal Finance',
    description: 'FIRE planning, emergency funds, and budgeting',
    count: 4,
    href: '/personal-finance',
    gradient: 'from-finance-500 to-finance-600',
    bgLight: 'bg-finance-50',
    borderColor: 'border-finance-100 hover:border-finance-300',
    textColor: 'text-finance-600',
  },
];

const featuredCalculators = [
  {
    name: 'Freelancer Hourly Rate',
    description: 'Factor in taxes, expenses, and profit margin to find the rate you should actually charge',
    href: '/freelance/hourly-rate-calculator',
    category: 'Freelance',
    categoryColor: 'text-freelance-600 bg-freelance-50',
  },
  {
    name: 'W2 vs 1099 Comparison',
    description: 'See the real difference between employee and contractor pay after taxes and benefits',
    href: '/freelance/w2-vs-1099-calculator',
    category: 'Freelance',
    categoryColor: 'text-freelance-600 bg-freelance-50',
  },
  {
    name: 'YouTube AdSense Revenue',
    description: 'Estimate your channel earnings based on views, CPM, and audience demographics',
    href: '/creator/youtube-adsense-calculator',
    category: 'Creator',
    categoryColor: 'text-creator-600 bg-creator-50',
  },
  {
    name: 'DoorDash Earnings',
    description: 'Calculate your real hourly pay after gas, vehicle wear, and self-employment tax',
    href: '/gig-economy/doordash-calculator',
    category: 'Gig Economy',
    categoryColor: 'text-gig-600 bg-gig-50',
  },
  {
    name: 'Etsy Fees Breakdown',
    description: 'See exactly how much Etsy takes from each sale and what you keep',
    href: '/creator/etsy-fee-calculator',
    category: 'Creator',
    categoryColor: 'text-creator-600 bg-creator-50',
  },
  {
    name: 'Quarterly Tax Estimator',
    description: 'Estimate your quarterly tax payments so you never get surprised in April',
    href: '/freelance/quarterly-tax-calculator',
    category: 'Freelance',
    categoryColor: 'text-freelance-600 bg-freelance-50',
  },
];
---

<BaseLayout
  title="CalcFalcon - Free Calculators for Freelancers, Creators & Side Hustlers"
  description="Free financial calculators for freelancers, content creators, and side hustlers. Calculate rates, estimate revenue, and plan your path to financial goals."
>
  <!-- Hero Section -->
  <section class="relative py-20 md:py-32 overflow-hidden bg-neutral-950">
    <div class="absolute inset-0 opacity-30" style="background-image: radial-gradient(circle at 20% 50%, rgba(6, 182, 212, 0.3) 0%, transparent 50%), radial-gradient(circle at 80% 50%, rgba(168, 85, 247, 0.2) 0%, transparent 50%);"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <!-- Announcement Badge -->
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-neutral-800/50 rounded-full border border-neutral-700 mb-8">
          <span class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-primary-500"></span>
          </span>
          <span class="text-sm font-medium text-neutral-300">20 free calculators and counting</span>
        </div>

        <!-- Headline -->
        <h1 class="heading-xl text-white mb-6">
          Know your numbers<br />
          <span class="text-gradient">before you commit</span>
        </h1>

        <!-- Subheadline -->
        <p class="text-xl text-neutral-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          Whether you're setting freelance rates, estimating creator revenue, or tracking gig earnings &mdash; get the real math, not guesswork.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href="#calculators"
            class="px-8 py-4 bg-white text-neutral-900 font-semibold rounded-xl hover:bg-neutral-100 transition-all duration-200"
          >
            Explore Calculators
          </a>
          <a
            href="/freelance/hourly-rate-calculator"
            class="px-8 py-4 bg-neutral-800 text-white font-semibold rounded-xl border border-neutral-700 hover:border-neutral-500 transition-all duration-200"
          >
            Try Rate Calculator
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Categories Section -->
  <section class="py-20 bg-white" id="categories">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="heading-lg text-neutral-900 mb-4">
          Browse by Category
        </h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">
          Find the right calculator for your situation
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-6">
        {categories.map((cat) => (
          <a
            href={cat.comingSoon ? '#' : cat.href}
            class={`group block p-6 rounded-2xl border bg-white transition-all duration-300 ${cat.borderColor} ${
              cat.comingSoon ? 'opacity-60 cursor-not-allowed' : 'hover:shadow-xl hover:-translate-y-1'
            }`}
          >
            <!-- Gradient Icon Square -->
            <div class={`w-12 h-12 rounded-xl bg-gradient-to-br ${cat.gradient} mb-4`}></div>

            <h3 class="font-semibold text-neutral-900 text-lg flex items-center gap-2">
              {cat.name}
              {cat.comingSoon && (
                <span class="text-xs bg-neutral-100 text-neutral-500 px-2 py-0.5 rounded-full font-medium">
                  Soon
                </span>
              )}
            </h3>
            <p class="text-sm text-neutral-500 mt-2 leading-relaxed">{cat.description}</p>
            {cat.count && (
              <p class={`text-xs font-medium mt-3 ${cat.textColor}`}>{cat.count} calculator{cat.count > 1 ? 's' : ''}</p>
            )}

            {!cat.comingSoon && (
              <div class={`mt-4 flex items-center gap-1 text-sm font-medium ${cat.textColor} opacity-0 group-hover:opacity-100 transition-opacity`}>
                <span>Explore</span>
                <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
              </div>
            )}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured Calculators Section -->
  <section class="py-20 bg-neutral-50" id="calculators">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="heading-lg text-neutral-900 mb-4">
          Popular Calculators
        </h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">
          The tools freelancers, creators, and gig workers use most
        </p>
      </div>

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {featuredCalculators.map((calc) => (
          <a
            href={calc.href}
            class="group block p-6 bg-white rounded-2xl border border-neutral-100 hover:border-neutral-200 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
          >
            <span class={`inline-block text-xs font-semibold uppercase tracking-wider px-3 py-1 rounded-full ${calc.categoryColor}`}>
              {calc.category}
            </span>
            <h3 class="font-bold text-neutral-900 text-lg mt-4 group-hover:text-primary-600 transition-colors">
              {calc.name}
            </h3>
            <p class="text-sm text-neutral-500 mt-2 leading-relaxed">{calc.description}</p>
            <div class="mt-5 flex items-center gap-2 text-primary-600 font-semibold text-sm">
              <span>Try it free</span>
              <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why CalcFalcon Section -->
  <section class="py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <h2 class="heading-lg text-neutral-900 mb-4">
          Why CalcFalcon?
        </h2>
        <p class="text-neutral-600 max-w-2xl mx-auto">
          No sign-ups. No spreadsheets. Just answers.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-10">
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-600 flex items-center justify-center mx-auto mb-5 shadow-lg shadow-primary-500/25">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg text-neutral-900">Built for Your Work</h3>
          <p class="text-neutral-500 mt-3 leading-relaxed">Every calculator is tailored to freelancers, creators, and gig workers &mdash; not generic finance formulas.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-sidehustle-500 to-sidehustle-600 flex items-center justify-center mx-auto mb-5 shadow-lg shadow-sidehustle-500/25">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
          <h3 class="font-bold text-lg text-neutral-900">Share With a Link</h3>
          <p class="text-neutral-500 mt-3 leading-relaxed">Every calculation gets a unique URL. Share results with clients, partners, or embed on your own site.</p>
        </div>
        <div class="text-center">
          <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-creator-500 to-creator-600 flex items-center justify-center mx-auto mb-5 shadow-lg shadow-creator-500/25">
            <svg class="w-7 h-7 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
            </svg>
          </div>
          <h3 class="font-bold text-lg text-neutral-900">Nothing Leaves Your Browser</h3>
          <p class="text-neutral-500 mt-3 leading-relaxed">Your financial data is yours. All calculations run locally &mdash; we don't store, track, or sell anything.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 bg-neutral-950">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="heading-lg text-white mb-6">
        Stop guessing. Start calculating.
      </h2>
      <p class="text-neutral-400 text-lg mb-10 max-w-2xl mx-auto">
        20 free calculators built for the way you actually work. Pick one and get your answer in under a minute.
      </p>
      <a
        href="/freelance/hourly-rate-calculator"
        class="inline-flex items-center gap-2 px-8 py-4 bg-gradient-to-r from-primary-500 to-sidehustle-500 text-white font-semibold rounded-xl hover:opacity-90 transition-opacity shadow-lg shadow-primary-500/25"
      >
        <span>Get Started Free</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>
</BaseLayout>
