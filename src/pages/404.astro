---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page Not Found - CalcFalcon"
  description="The page you're looking for doesn't exist."
  noIndex={true}
>
  <section class="py-20 md:py-32">
    <div class="max-w-2xl mx-auto px-4 text-center">
      <p class="text-7xl font-extrabold text-gradient mb-6">404</p>
      <h1 class="heading-lg text-neutral-900 mb-4">Page not found</h1>
      <p class="text-lg text-neutral-600 mb-10">
        The calculator you're looking for doesn't exist or may have moved.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/"
          class="px-8 py-4 bg-neutral-900 text-white font-semibold rounded-xl hover:bg-neutral-800 transition-all duration-200"
        >
          Back to Home
        </a>
        <a
          href="/#categories"
          class="px-8 py-4 bg-white text-neutral-900 font-semibold rounded-xl border border-neutral-200 hover:border-neutral-300 transition-all duration-200"
        >
          Browse Categories
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
