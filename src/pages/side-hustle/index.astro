---
import BaseLayout from '@layouts/BaseLayout.astro';
import SchemaOrg from '@components/seo/SchemaOrg.astro';
import type { FAQ } from '@lib/seo/schema';

const faqs: FAQ[] = [
  {
    question: 'How much can I make with a side hustle?',
    answer: 'It depends on the type and time invested. Service-based side hustles (freelancing, tutoring) typically earn $25-75 per hour. Product-based businesses have lower margins but can scale. Most side hustlers earn $500-2,000 per month.',
  },
  {
    question: 'Do I need to pay taxes on side hustle income?',
    answer: 'Yes, if you earn $400 or more in net self-employment income. You\'ll owe self-employment tax (15.3%) plus income tax. Set aside 25-30% of earnings for taxes and make quarterly estimated payments.',
  },
  {
    question: 'How do I balance a side hustle with a full-time job?',
    answer: 'Start with 5-10 hours per week. Focus on high-value activities that move the needle. Use our Time to Goal calculator to set realistic timelines. Avoid burnout by scheduling dedicated hustle time and protecting your rest days.',
  },
];

const calculators = [
  {
    name: 'Side Hustle Time to Goal Calculator',
    description: 'Calculate how long your side hustle will take to reach your financial goal',
    href: '/side-hustle/time-to-goal-calculator',
  },
  {
    name: 'Reselling Profit Calculator',
    description: 'Calculate your reselling profit after platform fees, shipping, and costs on eBay, Poshmark, Mercari, and more',
    href: '/side-hustle/reselling-profit-calculator',
  },
  {
    name: 'Freelance Writing Rate Calculator',
    description: 'Calculate your per-word and per-article rate based on time, experience, and desired income',
    href: '/side-hustle/freelance-writing-rate-calculator',
  },
  {
    name: 'Tutoring Income Calculator',
    description: 'Calculate your tutoring earnings after platform fees, prep time, and expenses',
    href: '/side-hustle/tutoring-income-calculator',
  },
  {
    name: 'Dropshipping Margin Calculator',
    description: 'Analyze your true dropshipping profit after supplier costs, ads, fees, returns, and refunds',
    href: '/side-hustle/dropshipping-margin-calculator',
  },
  {
    name: 'Profit Margin Calculator',
    description: 'Calculate gross, operating, and net profit margins with cost breakdown analysis',
    href: '/side-hustle/profit-margin-calculator',
  },
];
---

<BaseLayout
  title="Side Hustle Calculators - Plan Your Goals | CalcFalcon"
  description="Free calculators for side hustlers. Plan your path to financial goals and track your progress."
>
  <Fragment slot="head">
    <SchemaOrg faqs={faqs} />
  </Fragment>

  <!-- Hero Section -->
  <section class="bg-gradient-to-br from-sidehustle-500 to-sidehustle-600 text-white py-16 md:py-20">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <div class="w-16 h-16 rounded-2xl bg-white/20 backdrop-blur flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
        </svg>
      </div>
      <h1 class="heading-lg mb-4">Side Hustle Calculators</h1>
      <p class="text-xl text-white/80 max-w-2xl mx-auto">
        Tools to help you plan and achieve your side hustle goals
      </p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-12 bg-white border-b border-neutral-100">
    <div class="max-w-3xl mx-auto px-4">
      <p class="text-neutral-700 leading-relaxed mb-4">
        Building a side hustle is a path to financial freedom, but it requires planning. Whether you're saving for a specific goal or building toward full-time self-employment, knowing your numbers is essential to staying on track and making smart decisions.
      </p>
      <p class="text-neutral-700 leading-relaxed">
        These calculators help you set realistic timelines, calculate rates and margins, understand the tax implications of extra income, and map out the financial journey from side project to serious revenue stream.
      </p>
    </div>
  </section>

  <!-- Calculators List -->
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="grid gap-6">
        {calculators.map((calc) => (
          <a
            href={calc.href}
            class="group block p-6 bg-white rounded-2xl border border-neutral-100 hover:border-sidehustle-200 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
          >
            <h2 class="font-bold text-xl text-neutral-900 group-hover:text-sidehustle-600 transition-colors">
              {calc.name}
            </h2>
            <p class="text-neutral-600 mt-2 leading-relaxed">{calc.description}</p>
            <span class="inline-flex items-center text-sidehustle-600 font-semibold mt-4 group-hover:gap-2 transition-all">
              Use Calculator
              <svg class="w-4 h-4 ml-1 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
              </svg>
            </span>
          </a>
        ))}
      </div>

      <!-- FAQs -->
      <div class="mt-12">
        <h2 class="heading-md text-neutral-900 mb-6">Frequently Asked Questions</h2>
        <div class="space-y-3">
          {faqs.map((faq) => (
            <details class="card-elevated p-5 group">
              <summary class="font-medium text-neutral-900 cursor-pointer list-none flex justify-between items-center gap-4">
                <span>{faq.question}</span>
                <svg class="w-5 h-5 text-neutral-400 flex-shrink-0 group-open:rotate-180 transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="mt-4 text-neutral-600 leading-relaxed">{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
