---
import BaseLayout from '@layouts/BaseLayout.astro';
import ContactForm from '@components/ContactForm.tsx';
---

<BaseLayout
  title="Contact Us | CalcFalcon"
  description="Get in touch with the CalcFalcon team. Questions, feedback, or partnership inquiries welcome."
>
  <div class="py-16">
    <div class="max-w-2xl mx-auto px-4">
      <h1 class="heading-lg mb-4">Contact Us</h1>
      <p class="text-neutral-400 text-lg mb-10">
        Have a question, suggestion, or feedback? Fill out the form below and we'll get back to you.
      </p>

      <ContactForm client:load />
    </div>
  </div>
</BaseLayout>
