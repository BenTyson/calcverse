---
interface Props {
  calculatorName: string;
  calculatorSlug: string;
  category: string;
}

const { calculatorName, calculatorSlug, category } = Astro.props;

// Normalize blog categories to CSS class prefixes
const categoryMap: Record<string, string> = {
  freelance: 'freelance',
  creator: 'creator',
  'gig-economy': 'gig',
  'side-hustle': 'sidehustle',
  finance: 'finance',
};

const cat = categoryMap[category] || 'freelance';

// Tailwind needs literal class strings — no dynamic construction
const gradientBarClasses: Record<string, string> = {
  freelance: 'bg-gradient-freelance',
  creator: 'bg-gradient-creator',
  gig: 'bg-gradient-gig',
  sidehustle: 'bg-gradient-sidehustle',
  finance: 'bg-gradient-finance',
};

const textGradientClasses: Record<string, string> = {
  freelance: 'text-gradient-freelance',
  creator: 'text-gradient-creator',
  gig: 'text-gradient-gig',
  sidehustle: 'text-gradient-sidehustle',
  finance: 'text-gradient-finance',
};

const glowClasses: Record<string, string> = {
  freelance: 'shadow-glow-freelance',
  creator: 'shadow-glow-creator',
  gig: 'shadow-glow-gig',
  sidehustle: 'shadow-glow-sidehustle',
  finance: 'shadow-glow-finance',
};

const glowBgClasses: Record<string, string> = {
  freelance: 'bg-[rgba(6,182,212,0.15)]',
  creator: 'bg-[rgba(236,72,153,0.15)]',
  gig: 'bg-[rgba(16,185,129,0.15)]',
  sidehustle: 'bg-[rgba(168,85,247,0.15)]',
  finance: 'bg-[rgba(245,158,11,0.15)]',
};

const gradientBar = gradientBarClasses[cat];
const textGradient = textGradientClasses[cat];
const glowShadow = glowClasses[cat];
const glowBg = glowBgClasses[cat];
---

<div class="not-prose my-10">
  <div class="relative bg-neutral-950 rounded-2xl overflow-hidden">
    <!-- Gradient top bar -->
    <div class={`h-1 ${gradientBar}`}></div>

    <!-- Radial glow background -->
    <div class={`absolute top-0 right-0 w-1/2 h-full rounded-full blur-3xl opacity-20 pointer-events-none ${glowBg}`}></div>

    <!-- Content -->
    <div class="relative flex flex-col md:flex-row items-center gap-4 md:gap-6 p-6 md:p-8">
      <!-- Icon -->
      <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-white/10 flex items-center justify-center">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25v-.008Zm0 2.25h.008v.008H8.25v-.008Zm2.25-4.5h.008v.008H10.5v-.008Zm0 2.25h.008v.008H10.5v-.008Zm0 2.25h.008v.008H10.5v-.008Zm2.25-4.5h.008v.008H12.75v-.008Zm0 2.25h.008v.008H12.75v-.008Zm2.25-2.25h.008v.008H15v-.008Zm0 2.25h.008v.008H15v-.008ZM6 18.75a2.25 2.25 0 0 1-2.25-2.25V6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v1.5m3.75 0A2.25 2.25 0 0 1 16.5 5.25H18A2.25 2.25 0 0 1 20.25 7.5v9A2.25 2.25 0 0 1 18 18.75h-2.25m-7.5 0h7.5" />
        </svg>
      </div>

      <!-- Text -->
      <div class="flex-1 text-center md:text-left">
        <p class="text-white font-bold text-lg">Run the Numbers</p>
        <p class={`text-sm font-semibold ${textGradient}`}>Try the {calculatorName}</p>
      </div>

      <!-- Button -->
      <a
        href={calculatorSlug}
        class={`flex-shrink-0 inline-flex items-center gap-2 px-5 py-2.5 ${gradientBar} text-white font-semibold rounded-xl transition-all hover:opacity-90 ${glowShadow}`}
      >
        Open Calculator
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </div>
</div>
